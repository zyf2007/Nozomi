NOZOMI_HTTP_ADDR=0.0.0.0:5000
NOZOMI_SMTP_ADDR=0.0.0.0:2525
NOZOMI_DATA_DIR=data
NOZOMI_DB_PATH=data/nozomi.sqlite3
# 逗号分隔，填前端实际访问的 origin，例如 http://192.168.31.221:5173
NOZOMI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 单管理员账号；首次启动请改掉默认密码。
NOZOMI_ADMIN_USERNAME=admin
NOZOMI_ADMIN_PASSWORD=change-me
NOZOMI_SESSION_SECRET=change-this-session-secret
